{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["every weekend"],
  "commitMessagePrefix": "chore(deps):",
  "semanticCommits": "enabled",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    },
    {
      "groupName": "Next.js",
      "matchPackageNames": ["next", "react", "react-dom", "@types/react", "@types/react-dom"]
    },
    {
      "groupName": "Prisma",
      "matchPackageNames": ["prisma", "@prisma/client"]
    },
    {
      "groupName": "ESLint",
      "matchPackageNames": ["/eslint/"]
    },
    {
      "groupName": "Tailwind CSS",
      "matchPackageNames": ["/tailwind/"]
    },
    {
      "groupName": "Radix UI",
      "matchPackageNames": ["/@radix-ui//"]
    },
    {
      "groupName": "Vitest",
      "matchPackageNames": ["/vitest/", "@testing-library/**"]
    },
    {
      "groupName": "Playwright",
      "matchPackageNames": ["/playwright/"]
    },
    {
      "matchPackageNames": ["eslint"],
      "allowedVersions": "<10.0.0",
      "description": "eslint-plugin-react@7.x uses context.getFilename() removed in ESLint 10 — re-enable when eslint-plugin-react supports ESLint 10"
    },
    {
      "matchPackageNames": ["@vitejs/plugin-react"],
      "allowedVersions": "<6.0.0",
      "description": "@vitejs/plugin-react@6.x requires vite@^8.0.0 — re-enable when vite is also upgraded to v8"
    }
  ]
}
