    "pg-cloudflare": "^1.3.0",
    "prisma": "^7.7.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
