generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String                @id @default(cuid())
  name                 String?
  email                String?               @unique
  emailVerified        DateTime?
  password             String?
  image                String?
  customAvatarUrl      String?
  createdAt            DateTime              @default(now())
  discordUsername      String?
  discordId            String?               @unique
  role                 UserRole              @default(USER)
  pathfinder           Boolean               @default(false)
  bio                  String?
  commissionOpen       Boolean               @default(false)
  portfolioUrl         String?
  pinnedEstateId         String?
  designer               Boolean               @default(false)
  // Designer commission extended fields
  designerSpecialties    String[]              @default([])
  designerStyleTags      String[]              @default([])
  designerPricingText    String?
  designerTurnaround     String?
  // Notification preferences
  emailOnInquiry         Boolean               @default(true)
  emailOnMessage         Boolean               @default(true)
  lastSeenAt             DateTime?
  accounts               Account[]
  comments               Comment[]
  flaggedEstates         Estate[]              @relation("FlaggedByUser")
  estates                Estate[]
  characters             FfxivCharacter[]
  collections            Collection[]
  legalPageEdits         LegalPage[]           @relation("LegalPageEditor")
  likes                  Like[]
  sessions               Session[]
  venueStaff             VenueStaff[]          @relation("StaffUser")
  verificationReviews    EstateVerification[]  @relation("VerificationReviewer")
  pinnedEstate           Estate?               @relation("PinnedEstate", fields: [pinnedEstateId], references: [id])
  designedEstates        Estate[]              @relation("DesignedEstates")
  claimRequests          EstateClaimRequest[]  @relation("ClaimRequests")
  claimReviews           EstateClaimRequest[]  @relation("ClaimReviewer")
  designerConversations  Conversation[]        @relation("DesignerConversations")
  requestorConversations Conversation[]        @relation("RequestorConversations")
  sentMessages           Message[]             @relation("SentMessages")
  pushSubscriptions      PushSubscription[]
}

model FfxivCharacter {
  id                    String                 @id @default(cuid())
  userId                String
  lodestoneId           String
  characterName         String
  server                String
  verified              Boolean                @default(false)
  createdAt             DateTime               @default(now())
  avatarUrl             String                 @default("")
  dataCenter            String                 @default("")
  estates               Estate[]
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lodestoneVerification LodestoneVerification?
  venueStaffLinks       VenueStaff[]           @relation("StaffCharacter")
  claimRequests         EstateClaimRequest[]

  @@unique([userId, lodestoneId])
}

model Estate {
  id                 String                 @id @default(cuid())
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  published          Boolean                @default(false)
  name               String
  description        String
  inspiration        String
  type               EstateType
  district           HousingDistrict?
  region             String
  dataCenter         String
  server             String
  ward               Int?
  plot               Int?
  tags               String[]
  likeCount          Int                    @default(0)
  commentCount       Int                    @default(0)
  ownerId            String
  characterId        String?
  room               Int?
  subdivision        String?
  flagReason         String?
  flagged            Boolean                @default(false)
  flaggedAt          DateTime?
  flaggedById        String?
  moderationStatus   ModerationStatus       @default(PENDING)
  deletedAt          DateTime?
  verified           Boolean                @default(false)
  verificationStatus VerificationStatus?
  designerId         String?
  claimedAt          DateTime?
  confirmedActiveAt  DateTime?
  comments           Comment[]
  character          FfxivCharacter?        @relation(fields: [characterId], references: [id])
  flaggedBy          User?                  @relation("FlaggedByUser", fields: [flaggedById], references: [id])
  owner              User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  designer           User?                  @relation("DesignedEstates", fields: [designerId], references: [id])
  pinnedByUsers      User[]                 @relation("PinnedEstate")
  pendingTransfer    EstatePendingTransfer?
  claimRequest       EstateClaimRequest?
  images             Image[]
  likes              Like[]
  venueDetails       VenueDetails?
  verification       EstateVerification?
  collectionEntries  CollectionEstate[]
}

model EstateVerification {
  id           String             @id @default(cuid())
  estateId     String             @unique
  screenshotUrl   String
  storageKey      String
  submittedAt  DateTime           @default(now())
  reviewedAt   DateTime?
  status       VerificationStatus @default(PENDING)
  aiConfidence String?
  aiReason     String?
  modReason    String?
  reviewedById String?

  estate       Estate  @relation(fields: [estateId], references: [id], onDelete: Cascade)
  reviewedBy   User?   @relation("VerificationReviewer", fields: [reviewedById], references: [id])
}

model EstatePendingTransfer {
  id             String   @id @default(cuid())
  estateId       String   @unique
  newOwnerId     String
  newCharacterId String
  token          String   @unique @default(cuid())
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  estate         Estate   @relation(fields: [estateId], references: [id], onDelete: Cascade)
}

model Image {
  id         String @id @default(cuid())
  estateId   String
  imageUrl   String
  storageKey String
  order      Int    @default(0)
  estate     Estate @relation(fields: [estateId], references: [id], onDelete: Cascade)
}

model VenueDetails {
  id        String       @id @default(cuid())
  estateId  String       @unique
  venueType VenueType
  timezone  String       @default("UTC")
  hours     Json?
  estate    Estate       @relation(fields: [estateId], references: [id], onDelete: Cascade)
  staff     VenueStaff[]
}

model VenueStaff {
  id                String          @id @default(cuid())
  venueId           String
  characterName     String
  role              String
  linkedUserId      String?
  linkedCharacterId String?
  linkedCharacter   FfxivCharacter? @relation("StaffCharacter", fields: [linkedCharacterId], references: [id])
  linkedUser        User?           @relation("StaffUser", fields: [linkedUserId], references: [id])
  venue             VenueDetails    @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model Like {
  userId    String
  estateId  String
  createdAt DateTime @default(now())
  estate    Estate   @relation(fields: [estateId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, estateId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())
  userId    String
  estateId  String
  estate    Estate   @relation(fields: [estateId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LodestoneVerification {
  id          String         @id @default(cuid())
  code        String
  expiresAt   DateTime
  verified    Boolean        @default(false)
  characterId String         @unique
  character   FfxivCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model LegalPage {
  slug        String   @id
  title       String
  content     String
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("LegalPageEditor", fields: [updatedById], references: [id])
}

model SiteSettings {
  id              String  @id @default("singleton")
  maintenanceMode Boolean @default(false)
  disputeEmail    String  @default("dispute@eorzeaestates.com")
}

model EstateClaimRequest {
  id            String             @id @default(cuid())
  estateId      String             @unique
  claimantId    String
  characterId   String
  screenshotUrl String
  storageKey    String
  submittedAt   DateTime           @default(now())
  reviewedAt    DateTime?
  status        VerificationStatus @default(PENDING)
  reviewedById  String?
  modReason     String?
  estate        Estate             @relation(fields: [estateId], references: [id], onDelete: Cascade)
  claimant      User               @relation("ClaimRequests", fields: [claimantId], references: [id])
  character     FfxivCharacter     @relation(fields: [characterId], references: [id])
  reviewedBy    User?              @relation("ClaimReviewer", fields: [reviewedById], references: [id])
}

model Collection {
  id          String             @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  estates     CollectionEstate[]
}

model CollectionEstate {
  collectionId String
  estateId     String
  order        Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  estate       Estate     @relation(fields: [estateId], references: [id], onDelete: Cascade)

  @@id([collectionId, estateId])
}

model Conversation {
  id              String           @id @default(cuid())
  designerId      String
  requestorId     String
  estateType      EstateType?
  district        HousingDistrict?
  budgetRange     String?
  timeframe       String?
  designerReadAt  DateTime?
  requestorReadAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  designer        User             @relation("DesignerConversations", fields: [designerId], references: [id], onDelete: Cascade)
  requestor       User             @relation("RequestorConversations", fields: [requestorId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@unique([designerId, requestorId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum EstateType {
  PRIVATE
  FC_ESTATE
  VENUE
  APARTMENT
  FC_ROOM
}

enum HousingDistrict {
  MIST
  LAVENDER_BEDS
  GOBLET
  SHIROGANE
  EMPYREUM
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum VerificationStatus {
  PENDING
  AI_APPROVED
  QUEUED
  MOD_APPROVED
  MOD_REJECTED
}

enum VenueType {
  BAR
  NIGHTCLUB
  CAFE
  RESTAURANT
  GALLERY
  LIBRARY
  SHOP
  BATHHOUSE
  INN
  OTHER
}
